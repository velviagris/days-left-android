<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 整个组合居中并缩放，以适应 108dp 的画布 -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:translateX="0"
        android:translateY="3">

        <!-- 1. 皇冠填充层：填充白色，并利用 evenOdd 将眼睛区域挖空（透明） -->
        <path
            android:fillColor="#FFA726"
            android:fillType="evenOdd"
            android:pathData="M20,78 L88,78 L98,30 L78,48 L54,18 L30,48 L10,30 Z M40,62 A4.5,4.5 0 1,1 39.9,62 Z M68,62 A4.5,4.5 0 1,1 67.9,62 Z" />

        <!-- 2. 皇冠轮廓层：仅做白色描边，提供边缘质感 -->
        <path
            android:strokeColor="#FFA726"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M20,78 L88,78 L98,30 L78,48 L54,18 L30,48 L10,30 Z" />
    </group>
</vector>